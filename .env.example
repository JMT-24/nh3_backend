# --- Server ---
PORT=4000
# Comma-separated list of allowed CORS origins (the frontend dev + prod URLs).
ALLOWED_ORIGINS=http://localhost:5173

# --- Pi <-> Cloud auth ---
# Shared secret the Raspberry Pi must send as `x-api-key` on /api/ingest and /api/control/*.
# Generate something long & random, e.g. `node -e "console.log(crypto.randomUUID())"`.
INGEST_API_KEY=change-me-to-a-long-random-string

# --- Storage ---
# Path to the SQLite database file. Created automatically on first run.
DB_PATH=./data/nh3.db

# Durable cloud store (optional). BLANK = disabled: pure local SQLite, as before.
# When set, SQLite stays the fast local working set, every write is mirrored to
# MongoDB, and an empty SQLite is rehydrated from Mongo on boot (survives a
# Railway redeploy that wipes the disk). Requires the driver: `npm i mongodb`.
# Example: mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=nh3

# --- SMS ---
# Provider selection: blank = auto-detect by which key is set below.
# Force one with: unismsapi | unisms | stub
SMS_PROVIDER=

# TEMPORARY (dev only): allow the frontend "Send Test SMS" button to call
# /api/alerts/test without the api key. Keep OFF (blank/false) in production.
ENABLE_TEST_SMS_BUTTON=

# SMS frugality controls (SMS is sent ONCE when a sensor enters a critical state):
# Re-text if a critical condition is STILL active this many seconds later. 0 = never.
SMS_RENOTIFY_SEC=0
# Hard ceiling on SMS per calendar day (cost backstop). 0 = unlimited.
SMS_DAILY_CAP=50

# unismsapi.com  (Philippines — recommended). Your secret API key from the dashboard.
# Leave blank to keep the free logging "stub" (messages are printed, not sent).
UNISMSAPI_KEY=
# Optional branded sender ID; blank uses the default system sender.
UNISMSAPI_SENDER=

# unisms.apistd.com  (China aggregator — alternative). Signature/template based.
UNISMS_ACCESS_KEY_ID=
UNISMS_ACCESS_KEY_SECRET=
UNISMS_SIGNATURE=UniSMS
UNISMS_TEMPLATE_ID=
